{
  "name": "@aure/alpha",
  "version": "0.1.0",
  "description": "RAG engine for Aure — local-first, hardware-aware retrieval",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/cli/main.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "aure": "tsx src/cli/main.ts"
